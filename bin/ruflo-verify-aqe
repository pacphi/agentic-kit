#!/usr/bin/env bash
#
# ruflo-verify-aqe — prove agentic-qe is actually BENEFITING from ruvector (RVF),
# not silently running on the SQLite/hnswlib fallback.
#
# agentic-qe can look installed and even have on-disk .rvf files while its live
# shared RVF adapter fails to initialize ("RVF error 0x0303: FsyncFailed", usually
# a corrupt/oversized pattern store) — in which case ruvector is OFF for the run.
# This asserts three things, and is the agentic-qe analogue of
# `ruflo-enable-learning --check` (which proves the ruflo side):
#
#   1. capability — `aqe upgrade --json` reports @ruvector/rvf-node "loaded"
#      and the RVF flags on (useRVFPatternStore, useNativeHNSW).
#   2. no corrupt store — no .agentic-qe/*.rvf over the sane size cap.
#   3. live init    — a real `aqe status` start does NOT print
#      "[RVF] Shared adapter init failed" / FsyncFailed.
#
# Optional native @ruvector/solver-node (sublinear PageRank) is reported as
# ADVISORY only — its absence is a graceful TS fallback, not a failure.
#
# Usage:
#   ruflo-verify-aqe            # assert AQE is on ruvector in THIS repo
#   ruflo-verify-aqe --repair   # quarantine a corrupt .rvf first, then assert
#   ruflo-verify-aqe --help
#
# Exit codes: 0 AQE on ruvector / 1 not on ruvector (assertion failed) / 2 env error
set -u
REPAIR=0
while (( $# )); do
	case "$1" in
		--repair) REPAIR=1 ;;
		-h|--help) sed -n '3,26p' "$0" | sed 's|^# \{0,1\}||'; exit 0 ;;
		*) echo "Unknown flag: $1 (try --help)" >&2; exit 2 ;;
	esac
	shift
done

# Shared helpers (colors, ok/warn/fail/dim, _ruflo_need) + the AQE ruvector repair
# helper from the shipped shell lib/functions: installed copies first, then
# repo-relative (bin/ ↔ ../shell/).
for _base in "$HOME/.config/ruflo" "$(dirname "${BASH_SOURCE[0]:-$0}")/../shell"; do
	# shellcheck source=/dev/null
	[ -f "$_base/ruflo-lib.sh" ]       && . "$_base/ruflo-lib.sh"
	# shellcheck source=/dev/null
	[ -f "$_base/ruflo-functions.sh" ] && . "$_base/ruflo-functions.sh"
	[ -n "${_RUFLO_LIB:-}" ] && break
done
unset _base
[ -n "${_RUFLO_LIB:-}" ] || { echo "ruflo-lib.sh not found — run install.sh" >&2; exit 2; }

_ruflo_need node aqe

echo "## agentic-qe ruvector verification"
[ -d .agentic-qe ] || dim "note: no .agentic-qe/ in $(pwd -P) — probing global aqe capability only"

# --repair: drop a corrupt/oversized .rvf before we assert live init.
if [ "$REPAIR" -eq 1 ] && command -v _ruflo_aqe_repair_rvf >/dev/null 2>&1; then
	_ruflo_aqe_repair_rvf
fi

fails=0

# --- (1) capability: native rvf-node loaded + RVF flags on --------------------
UPGRADE_JSON="$(aqe upgrade --json 2>/dev/null)"
if [ -z "$UPGRADE_JSON" ]; then
	warn "'aqe upgrade --json' produced no output — cannot read native-binding report"
	fails=1
else
	# Parse with node; print one ✓/⚠ per checked capability. Exit 3 on assertion miss.
	AQE_UPGRADE_JSON="$UPGRADE_JSON" node <<'NODE' || fails=1
const j = JSON.parse(process.env.AQE_UPGRADE_JSON);
const OK = '✓', WARN = '⚠';
const nat = (name) => (j.natives || []).find(n => n.packageName === name);
const flag = (k) => !!(j.flags || {})[k];
let bad = 0;

const rvf = nat('@ruvector/rvf-node');
if (rvf && rvf.status === 'loaded') console.log(`  ${OK} @ruvector/rvf-node loaded (persistent HNSW pattern store + RVF brain export)`);
else { console.log(`  ${WARN} @ruvector/rvf-node NOT loaded (${rvf ? rvf.status : 'absent'}) — RVF pattern store falls back to SQLite`); bad = 1; }

for (const f of ['useRVFPatternStore', 'useNativeHNSW']) {
  if (flag(f)) console.log(`  ${OK} flag ${f} on`);
  else { console.log(`  ${WARN} flag ${f} OFF`); bad = 1; }
}

// Advisory-only optional natives (graceful fallback; never fail the check).
for (const name of ['@ruvector/solver-node', '@ruvector/attention', '@ruvector/gnn']) {
  const n = nat(name);
  const loaded = n && n.status === 'loaded';
  console.log(`  ${loaded ? OK : WARN} ${name} ${loaded ? 'loaded' : '(optional, TS/JS fallback)'}`);
}
process.exit(bad ? 3 : 0);
NODE
fi

# --- (2) live init: shared RVF adapter must NOT FsyncFail ---------------------
# A real aqe start; we only care about the RVF init lines on stderr/stdout.
INIT_LOG="$(aqe status 2>&1)"
if printf '%s\n' "$INIT_LOG" | grep -qiE 'RVF.*init failed|FsyncFailed|0x0303'; then
	fail "live RVF adapter FAILED to initialize (FsyncFailed) — agentic-qe is running OFF ruvector"
	printf '%s\n' "$INIT_LOG" | grep -iE 'RVF' | sed 's/^/    /' | head -4
	dim "    fix: ruflo-verify-aqe --repair   (drops a corrupt .rvf so aqe rebuilds from memory.db)"
	fails=1
else
	ok "live RVF adapter initialized cleanly (no FsyncFailed)"
fi

echo ""
if [ "$fails" -eq 0 ]; then
	ok "agentic-qe is ON ruvector (native RVF pattern store + HNSW, live-verified)"
	exit 0
fi
warn "agentic-qe is NOT fully on ruvector — see docs/TROUBLESHOOTING.md §agentic-qe RVF FsyncFailed"
exit 1
